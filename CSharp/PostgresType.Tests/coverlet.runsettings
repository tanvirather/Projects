<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Include>[Zuhid.PostgresType]*</Include>
					<Exclude>[Zuhid.PostgresType]*PostgresTypeContext,[Zuhid.PostgresType]*Migrations.*,[Zuhid.PostgresType]*Entities.*,[Zuhid.PostgresType]*Program</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
